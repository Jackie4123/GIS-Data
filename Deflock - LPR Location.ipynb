    "import json\n",
    "import pandas as pd\n",
    "\n",
    "# Path to your Overpass export\n",
    "json_path = \"C:\\\\Users\\\\LPRC-Nik\\\\Downloads\\\\export (1).json\"   # change if needed\n",
    "\n",
    "# Load JSON\n",
    "with open(json_path, \"r\", encoding=\"utf-8\") as f:\n",
    "    data = json.load(f)\n",
    "\n",
    "rows = []\n",
    "\n",
    "for element in data[\"elements\"]:\n",
    "    if element[\"type\"] == \"node\":\n",
    "        row = {\n",
    "            \"osm_id\": element.get(\"id\"),\n",
    "            \"latitude\": element.get(\"lat\"),\n",
    "            \"longitude\": element.get(\"lon\")\n",
    "        }\n",
    "        \n",
    "        # Flatten tags\n",
    "        tags = element.get(\"tags\", {})\n",
    "        for key, value in tags.items():\n",
    "            clean_key = key.replace(\":\", \"_\")  # ArcGIS-friendly field names\n",
    "            row[clean_key] = value\n",
    "        \n",
    "        rows.append(row)\n",
    "\n",
    "# Create DataFrame\n",
    "df = pd.DataFrame(rows)\n",
    "\n",
    "# Sort by ID (optional)\n",
    "df = df.sort_values(\"osm_id\")\n",
    "\n",
    "# Display first few rows\n",
    "print(df.head())\n",
    "\n",
    "# Save to CSV (for ArcGIS / Excel)\n",
    "df.to_csv(\"C:\\\\Users\\\\LPRC-Nik\\\\OneDrive - Loss Prevention Research Council\\\\Desktop\\\\SaferPlace Gainesville\\\\Data\\\\gainesville_flock_sensors.csv\", index=False) # change if needed\n",
    "\n",
    "print(\"Attribute table saved as gainesville_flock_sensors.csv\")"
   ]
  },
  {
